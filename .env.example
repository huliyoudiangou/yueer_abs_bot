# ==========================================
# 基础与安全配置
# ==========================================
TELEGRAM_BOT_TOKEN=在此填入你的BotToken
ADMIN_TELEGRAM_IDS=你的TG用户ID(多个用英文逗号隔开)
BACKUP_ENCRYPT_KEY=这里换成一串很长的随机密钥，建议至少64位
SECURITY_PEPPER=这里换成一串很长的随机密钥，建议至少64位

# ==========================================
# Audiobookshelf 服务器配置
# ==========================================
ABS_API_URL=https://你的ABS地址
# 仅本地测试 HTTP 时才打开：
# ALLOW_INSECURE_ABS_HTTP=true
ABS_API_KEY=你的ABS_API密钥
ABS_TEMPLATE_USER_ID=权限模板用户ID

# ==========================================
# 社群运营与通知配置
# ==========================================
NOTICE_GROUP_ID=-100123456789   # 主力宣发大群 (需将 Bot 设为管理员)
BACKUP_GROUP_ID=-100987654321   # 仅自己和 Bot 所在的私密频道 (用于接收数据库备份)
NOTIFY_BEFORE_DAYS=3            # 提前几天提醒到期

# ==========================================
# GitHub 福利配置
# ==========================================
# 可选：无权限 GitHub PAT，用于把 GitHub 福利校验从匿名 API 限额提升为认证请求限额
GITHUB_API_TOKEN=

# ==========================================
# 花园配置
# ==========================================
GARDEN_MINI_APP_ENABLED=true
GARDEN_MINI_APP_URL=https://你的公网域名/garden
GARDEN_MINI_APP_LISTEN=:28083

# ==========================================
# 注册与账号系统
# ==========================================
INVITE_REQUIRED=true            # 是否强制邀请码注册
ACCOUNT_VALID_DAYS=30           # 注册默认有效天数
ACCOUNT_GRACE_DAYS=30           # 过期后保留数据的宽限期天数

# ==========================================
# 高级系统与网络配置
# ==========================================
DATABASE_URL=data/bot_data.db   # 数据库文件挂载路径
WORKER_COUNT=30                 # 高并发工作池数量
QUEUE_CAPACITY=10000            # 队列容量
DATABASE_MAX_OPEN_CONNS=10        # SQLite WAL 模式下建议 3-10，不建议太大
DATABASE_MAX_IDLE_CONNS=10        # 建议和 MAX_OPEN_CONNS 一致或略小
DATABASE_BUSY_TIMEOUT_MS=10000   # SQLite 写锁等待时间，单位毫秒
BOT_STARTUP_NOTIFY_ADMINS=false  # 排查无响应时可临时设为 true，启动后私聊管理员发送自检通知
